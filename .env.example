# Assets API Configuration
# Copy this file to .env and fill in your actual values
# DO NOT commit .env to version control

# Firebase Configuration (for production backend)
# Get these values from: Firebase Console → Project Settings → Your apps → Web app
VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:abc123

# Legacy: Google Apps Script (not used due to CORS limitations)
# VITE_ASSETS_API_BASE_URL=https://script.google.com/macros/s/YOUR_SCRIPT_ID/exec
