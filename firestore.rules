rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Assets - public can read, only authenticated users can write
    match /assets/{document=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    // B2B Listings - public can read, only authenticated users can write
    match /b2b_listings/{document=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    // Drops - public can read, only authenticated users can write
    match /drops/{document=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    // User data - users can only read/write their own data
    // Allow access to the user document itself
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    // Allow access to subcollections under user document
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Trade Coordination (Pre-Exchange Phase)
    
    // Connection requests - users can read their own, write new ones
    match /connections/{connectionId} {
      allow read: if request.auth != null && 
                  (request.auth.uid == resource.data.requesterId || 
                   request.auth.uid == resource.data.targetId);
      allow create: if request.auth != null && 
                    request.auth.uid == request.resource.data.requesterId;
      allow update: if request.auth != null && 
                    (request.auth.uid == resource.data.requesterId || 
                     request.auth.uid == resource.data.targetId);
      allow delete: if request.auth != null && 
                    request.auth.uid == resource.data.requesterId;
    }
    
    // Trade listings - anyone can read (listings are public), only owner can write
    match /trade_listings/{listingId} {
      allow read: if true;
      allow create: if request.auth != null && 
                    request.auth.uid == request.resource.data.userId;
      allow update, delete: if request.auth != null && 
                            request.auth.uid == resource.data.userId;
    }
    
    // Trading profiles - users can read any profile, but only write their own
    match /trading_profiles/{userId} {
      allow read: if true; // Public profiles for reputation system
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Scraped prices - staging collection for marketplace scraper results
    // Analysts can read and update (approve/reject), Cloud Functions write via Admin SDK
    match /scraped_prices/{document=**} {
      allow read: if request.auth != null;
      allow update: if request.auth != null; // Analysts approve/reject
      // create/delete handled by Cloud Functions (Admin SDK bypasses rules)
    }
    
    // Scrape run summaries - read-only for authenticated users
    match /scrape_runs/{document=**} {
      allow read: if request.auth != null;
      // Writes handled by Cloud Functions (Admin SDK)
    }
    
    // Scrape progress - real-time progress tracking for the frontend
    match /scrape_progress/{document=**} {
      allow read: if true; // Public read for real-time progress display
      // Writes handled by Cloud Functions (Admin SDK)
    }
  }
}
