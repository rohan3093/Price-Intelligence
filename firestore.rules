rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: is the caller's email in the analysts list?
    function isAnalyst() {
      return request.auth != null
        && request.auth.token.email != null
        && request.auth.token.email.lower() in get(/databases/$(database)/documents/config/analysts).data.emails;
    }

    // Config — only analysts can read/write (prevents regular users from seeing the analyst list)
    match /config/{document=**} {
      allow read: if request.auth != null;
      allow write: if isAnalyst();
    }

    // Assets — public read, analyst-only write
    match /assets/{document=**} {
      allow read: if true;
      allow write: if isAnalyst();
    }

    // B2B Listings — public read, analyst-only write
    match /b2b_listings/{document=**} {
      allow read: if true;
      allow write: if isAnalyst();
    }

    // Drops — public read, analyst-only write
    match /drops/{document=**} {
      allow read: if true;
      allow write: if isAnalyst();
    }

    // User data — users can only read/write their own data
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Connection requests — scoped to participants
    match /connections/{connectionId} {
      allow read: if request.auth != null &&
                  (request.auth.uid == resource.data.requesterId ||
                   request.auth.uid == resource.data.targetId);
      allow create: if request.auth != null &&
                    request.auth.uid == request.resource.data.requesterId;
      allow update: if request.auth != null &&
                    (request.auth.uid == resource.data.requesterId ||
                     request.auth.uid == resource.data.targetId);
      allow delete: if request.auth != null &&
                    request.auth.uid == resource.data.requesterId;
    }

    // Trade listings — public read, owner-only write
    match /trade_listings/{listingId} {
      allow read: if true;
      allow create: if request.auth != null &&
                    request.auth.uid == request.resource.data.userId;
      allow update, delete: if request.auth != null &&
                            request.auth.uid == resource.data.userId;
    }

    // Trading profiles — public read, owner-only write
    match /trading_profiles/{userId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Price history — public read (powers the chart), writes only via Admin SDK
    // (the scheduled snapshot function bypasses these rules; client writes denied).
    match /priceHistory/{document=**} {
      allow read: if true;
      allow write: if false;
    }

    // Scraped prices — analyst-only read/update
    match /scraped_prices/{document=**} {
      allow read: if isAnalyst();
      allow update: if isAnalyst();
    }

    // Scrape run summaries — analyst-only read
    match /scrape_runs/{document=**} {
      allow read: if isAnalyst();
    }

    // Scrape progress — analyst-only read
    match /scrape_progress/{document=**} {
      allow read: if isAnalyst();
    }
  }
}
