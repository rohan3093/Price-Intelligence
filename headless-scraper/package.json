{
  "name": "headless-scraper",
  "version": "1.0.0",
  "private": true,
  "description": "Headless-browser scraper service for Cloudflare-protected sites (StockX, GOAT). Deployed to Cloud Run, called from Firebase Functions.",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "tsc -w & nodemon dist/server.js",
    "docker:build": "docker build -t headless-scraper .",
    "docker:run": "docker run --rm -p 8080:8080 -e SCRAPER_SHARED_SECRET=dev-secret headless-scraper"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "express": "^4.21.2",
    "playwright": "1.49.0",
    "playwright-extra": "^4.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.0",
    "nodemon": "^3.1.7",
    "typescript": "^5.4.5"
  }
}
